{
  "name": "tenzyudotcom",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter site dev",
    "dev:overlay": "bun run --filter site dev:overlay",
    "clean": "bun run --filter site clean",
    "build": "bun run --filter site build",
    "build:prod": "bun run --filter site build:prod",
    "start": "bun run --filter site start",
    "start:intlayer": "bun run --filter site start:intlayer",
    "lint": "bun run --filter site lint",
    "lint:fix": "bun run --filter site lint:fix",
    "lint:rules": "bun run --filter @tenzyu/linter lint:rules ../..",
    "docs-rename": "bun scripts/docs-rename.ts",
    "build:docs-map": "bun scripts/compile-agents-md.ts",
    "format": "bun run --filter site format",
    "test": "bun run --filter site test && bun run --filter @tenzyu/linter test && bun test scripts/compile-agents-md.test.ts scripts/docs-rename.test.ts",
    "verify:quick": "bun run lint && bun run lint:rules && bun run test",
    "verify": "bun run verify:quick && bun run build",
    "analyze": "bun run --filter site analyze"
  },
  "devDependencies": {
    "gray-matter": "^4.0.3"
  }
}
