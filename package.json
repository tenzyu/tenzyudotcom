{
  "name": "tenzyudotcom",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:overlay": "ENABLE_REACT_GRAB_OVERLAY=1 bunx @react-grab/codex@latest && ENABLE_REACT_GRAB_OVERLAY=1 intlayer watch --with 'next dev'",
    "clean": "rimraf .next",
    "build": "next build",
    "build:prod": "bun run clean && NODE_ENV=production bun --env-file .env.prod next build",
    "start": "bun run clean && bun run build && next start",
    "start:intlayer": "intlayer-editor start",
    "lint": "bun run lint:biome && bun run lint:custom",
    "lint:biome": "./scripts/biome lint .",
    "lint:custom": "bun run lint:no-reexport && bun run lint:import-boundaries && bun run lint:symbol-ownership && bun run lint:site-rules",
    "lint:no-reexport": "bun scripts/lint-no-reexport.ts",
    "lint:import-boundaries": "bun scripts/lint-import-boundaries.ts",
    "lint:symbol-ownership": "bun scripts/lint-symbol-ownership.ts",
    "lint:site-rules": "bun scripts/lint-site-rules.ts",
    "lint:fix": "./scripts/biome lint --fix .",
    "lint:docs": "bun scripts/lint-docs.ts",
    "docs-rename": "bun scripts/docs-rename.ts",
    "build:docs-map": "bun scripts/compile-agents-md.ts",
    "format": "./scripts/biome format --write .",
    "test": "bun test",
    "verify:quick": "bun run lint && bun run lint:docs && bun run test",
    "verify": "bun run verify:quick && bun run build",
    "analyze": "next experimental-analyze"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.3.1",
    "@vercel/speed-insights": "^1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "intlayer": "^8.2.2",
    "intlayer-editor": "^8.2.2",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-intlayer": "^8.2.2",
    "next-themes": "^0.4.6",
    "osu-api-v2-js": "^1.1.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.1",
    "react-tweet": "^3.3.0",
    "recharts": "2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@intlayer/swc": "^8.2.2",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.1.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "^1.3.10",
    "@types/mdx": "^2.0.13",
    "@types/picomatch": "^4.0.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "critters": "^0.0.25",
    "gray-matter": "^4.0.3",
    "picomatch": "^4.0.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  }
}
